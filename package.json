{
  "name": "wujieaichat-desktop",
  "version": "1.0.0",
  "description": "无界AI聊天的桌面版应用",
  "license": "SEE LICENSE IN LICENSE",
  "author": "BlackHoleEra-Team",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.wujieaichat.desktop",
    "productName": "无界AI聊天",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!.git",
      "!dist/",
      "!build/",
      "!out/",
      "!logs/",
      "!*.log",
      "!.env",
      "!.vscode/",
      "!.idea/",
      "!.DS_Store",
      "!Thumbs.db",
      "!build.log",
      "!examples/",
      "!wujie-old-code/",
      "!npm-debug.log*",
      "!yarn-debug.log*",
      "!yarn-error.log*",
      "!node_modules/.bin/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.map",
      "!node_modules/**/test*/**",
      "!node_modules/**/tests*/**",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/doc/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/example/**",
      "!node_modules/**/samples/**",
      "!node_modules/**/.github/**",
      "!node_modules/**/.gitignore",
      "!node_modules/**/.eslintrc*",
      "!node_modules/**/.prettierrc*",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/LICENSE",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/HISTORY*",
      "!node_modules/**/AUTHORS*",
      "!node_modules/**/CONTRIBUTORS*",
      "!node_modules/**/PATENTS*",
      "!node_modules/**/NOTICE*",
      "!node_modules/**/src/**",
      "!node_modules/**/tsconfig.json",
      "!node_modules/**/webpack.config.js",
      "!node_modules/**/rollup.config.js",
      "!node_modules/**/.babelrc",
      "!node_modules/**/.editorconfig",
      "!node_modules/**/.travis.yml",
      "!node_modules/**/.appveyor.yml",
      "!node_modules/**/appveyor.yml",
      "!node_modules/**/jest.config.js",
      "!node_modules/**/karma.conf.js",
      "!node_modules/**/.nycrc",
      "!node_modules/**/.nycrc.json",
      "!node_modules/**/.coveralls.yml",
      "!node_modules/**/.istanbul.yml",
      "!node_modules/**/tslint.json",
      "!node_modules/**/tsconfig*.json",
      "!node_modules/**/typedoc.json",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/types/**",
      "!node_modules/**/@types/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "images/app-icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "images/app-icon.ico",
      "uninstallerIcon": "images/app-icon.ico",
      "installerHeaderIcon": "images/app-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "无界AI聊天",
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "cropperjs": "^1.6.2",
    "crypto-js": "^4.2.0",
    "jquery": "^3.7.1",
    "jquery-cropper": "^1.0.2",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.2"
  }
}
